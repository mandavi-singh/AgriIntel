model.pkl
encoders.pkl

# ─── Jupyter Notebooks ───────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

